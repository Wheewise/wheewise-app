# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host:5432/wheewise?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Cloudflare R2 (S3-compatible) for vehicle photos
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="wheewise-media"
R2_PUBLIC_BASE_URL="https://media.wheewise.com"

# Razorpay subscriptions
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Razorpay plan IDs (create in dashboard, paste here)
RAZORPAY_PLAN_MONTHLY=""
RAZORPAY_PLAN_YEARLY=""

# Resend (email)
RESEND_API_KEY=""
RESEND_FROM="Wheewise <noreply@wheewise.com>"

# Sentry (optional — error monitoring)
# SENTRY_DSN="https://<key>@<host>/<project>"
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@<host>/<project>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
