# Database (Neon Postgres)
DATABASE_URL="postgresql://user:password@host:5432/wheewise?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# Cloudflare R2 (S3-compatible) for vehicle photos
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="wheewise-media"
R2_PUBLIC_BASE_URL="https://media.wheewise.com"

# Razorpay subscriptions
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# Razorpay plan IDs (create in dashboard, paste here)
RAZORPAY_PLAN_MONTHLY=""
RAZORPAY_PLAN_YEARLY=""

# Resend (email)
RESEND_API_KEY=""
RESEND_FROM="Wheewise <noreply@wheewise.com>"

# Sentry (optional — error monitoring)
# SENTRY_DSN="https://<key>@<host>/<project>"
# NEXT_PUBLIC_SENTRY_DSN="https://<key>@<host>/<project>"

# SMS provider — set MSG91 (preferred for India) OR Twilio.
# Without either, sendSms() falls back to console in dev and THROWS in prod.
# MSG91_AUTH_KEY=""
# MSG91_SENDER_ID="WHWISE"
# MSG91_TEMPLATE_ID=""
# TWILIO_ACCOUNT_SID=""
# TWILIO_AUTH_TOKEN=""
# TWILIO_FROM_NUMBER="+1xxxxxxxxxx"

# KYC providers (GST + RTO lookups). When unset, /api/gst/verify returns 503
# and /api/rto returns 503. Mock data only emits with the WHEEWISE_MOCK_* flags
# below, AND only in NODE_ENV=development.
# SUREPASS_TOKEN=""
# SUREPASS_BASE_URL="https://kyc-api.surepass.io/api/v1"
# Optionally override RTO endpoint independently:
# RTO_PROVIDER_TOKEN=""
# RTO_PROVIDER_URL="https://kyc-api.surepass.io/api/v1"

# AI description generation (optional — falls back to template if not set)
# Set one or both; OpenAI is tried first, then Anthropic, then mock templates.
# OPENAI_API_KEY=""
# ANTHROPIC_API_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Dev-only flags. ALL of these refuse to boot when NODE_ENV=production
# (the server throws at startup). Each ALSO requires NODE_ENV=development
# at request time before any behavior changes.
#
# OTP_DEV_BYPASS=1            — force OTP "000000" in local dev.
# WHEEWISE_DEV_LOGIN=1        — enable the "dev: instant sign-in as dealer" login.
# WHEEWISE_MOCK_GST=1         — return fake GST verification data for any valid-format GSTIN.
# WHEEWISE_MOCK_RTO=1         — return fake RTO vehicle lookup data.
