// Wheewise — MVP schema
// See WHEEWISE_SDD.md §6 for the v2 superset.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// Auth + Users
// =============================================================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  phone         String?   @unique
  passwordHash  String
  name          String?
  role          Role      @default(BUYER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dealer        Dealer?
  enquiries     Enquiry[]
  sessions      Session[]
  accounts      Account[]
  savedListings SavedListing[]
  conversations Conversation[]
  messages      Message[]
}

// NextAuth Prisma adapter tables (kept minimal — Credentials provider
// only really needs User, but the adapter expects these too).

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================
// Dealer + Storefront
// =============================================================

model Dealer {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  city         String
  phone        String
  whatsapp     String?
  gstin        String?
  gstVerified   Boolean       @default(false)
  status       DealerStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store        Store?
  listings      Listing[]
  enquiries     Enquiry[]
  subscription  Subscription?
  conversations Conversation[]
  apiKeys       ApiKey[]
  payouts       Payout[]
}

model Store {
  id           String   @id @default(cuid())
  dealerId     String   @unique
  dealer       Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  slug         String   @unique
  logoUrl      String?
  bannerUrl    String?
  bio          String?
  primaryColor String   @default("#DC2626")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =============================================================
// Listings
// =============================================================

model Listing {
  id            String        @id @default(cuid())
  dealerId      String
  dealer        Dealer        @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  vehicleType   VehicleType
  make          String
  model         String
  year          Int
  fuelType      FuelType
  transmission  Transmission?
  odometerKm    Int
  askingPrice   Decimal       @db.Decimal(12, 2)
  description   String        @db.Text
  city          String
  status         ListingStatus @default(ACTIVE)
  viewCount      Int           @default(0)
  enquiryCount   Int           @default(0)
  isBoosted      Boolean       @default(false)
  boostExpiresAt DateTime?
  createdAt      DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  photos    ListingPhoto[]
  enquiries Enquiry[]
  savedBy       SavedListing[]
  conversations Conversation[]

  @@index([city, vehicleType, status])
  @@index([dealerId, status])
  @@index([status, createdAt])
}

model ListingPhoto {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)

  @@index([listingId, sortOrder])
}

// =============================================================
// Leads
// =============================================================

model Enquiry {
  id         String        @id @default(cuid())
  listingId  String
  listing    Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  dealerId   String
  dealer     Dealer        @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  buyerId    String?
  buyer      User?         @relation(fields: [buyerId], references: [id])
  buyerName  String
  buyerPhone String
  buyerEmail String?
  message    String?
  source     EnquirySource @default(FORM)
  priority   Int           @default(0)
  isRead     Boolean       @default(false)
  isContacted Boolean      @default(false)
  createdAt  DateTime      @default(now())

  @@index([dealerId, isRead, priority, createdAt])
  @@index([listingId, createdAt])
}

// =============================================================
// Chat
// =============================================================

model Conversation {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId   String
  buyer     User     @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([dealerId])
}

model Message {
  id             String    @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User      @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String    @db.Text
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([conversationId, createdAt])
}

// =============================================================
// Saved (wishlist)
// =============================================================

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// =============================================================
// Developer API
// =============================================================

model ApiKey {
  id        String   @id @default(cuid())
  dealerId  String
  dealer    Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  name      String
  key       String   @unique
  lastUsedAt DateTime?
  createdAt DateTime @default(now())

  @@index([dealerId])
  @@index([key])
}

// =============================================================
// Payouts
// =============================================================

model Payout {
  id               String       @id @default(cuid())
  dealerId         String
  dealer           Dealer       @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  amount           Decimal      @db.Decimal(12, 2)
  status           PayoutStatus @default(PENDING)
  razorpayPayoutId String?
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([dealerId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// =============================================================
// Notifications
// =============================================================

model NotificationTemplate {
  id        String   @id @default(cuid())
  name      String   @unique
  subject   String
  body      String   @db.Text
  type      TemplateType @default(EMAIL)
  updatedAt DateTime @updatedAt
}

enum TemplateType {
  EMAIL
  SMS
}

// =============================================================
// Subscriptions
// =============================================================

model Subscription {
  id               String    @id @default(cuid())
  dealerId         String    @unique
  dealer           Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  plan             PlanTier  @default(FREE_TRIAL)
  status           SubStatus @default(TRIALING)
  razorpaySubId    String?   @unique
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// =============================================================
// Enums
// =============================================================

enum Role {
  BUYER
  DEALER
  ADMIN
}

enum DealerStatus {
  ACTIVE
  SUSPENDED
}

enum VehicleType {
  CAR
  BIKE
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum Transmission {
  MANUAL
  AUTOMATIC
  AMT
  CVT
}

enum ListingStatus {
  ACTIVE
  PAUSED
  SOLD
}

enum EnquirySource {
  FORM
  WHATSAPP
  CALL
}

enum PlanTier {
  FREE_TRIAL
  MONTHLY
  YEARLY
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}
