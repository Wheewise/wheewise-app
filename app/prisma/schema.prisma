// Wheewise — MVP schema
// See WHEEWISE_SDD.md §6 for the v2 superset.

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================
// Auth + Users
// =============================================================

model User {
  id            String    @id @default(cuid())
  // email is nullable: phone-OTP only users have no email.
  // Prisma/PostgreSQL unique index correctly allows multiple NULLs.
  email         String?   @unique
  phone         String?   @unique
  // passwordHash is nullable: phone-OTP only users have no password.
  // Empty-string passwordHash from old rows is harmless (bcrypt.compare to "" is false).
  passwordHash  String?
  name          String?
  role          Role      @default(BUYER)
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  dealer           Dealer?
  enquiries        Enquiry[]
  sessions         Session[]
  accounts         Account[]
  savedListings    SavedListing[]
  conversations    Conversation[]
  messages         Message[]
  inspector        Inspector?
  posts            Post[]
  replies          Reply[]
  postUpvotes      PostUpvote[]
  loanApplications LoanApplication[]
}

// NextAuth Prisma adapter tables (kept minimal — Credentials provider
// only really needs User, but the adapter expects these too).

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =============================================================
// Dealer + Storefront
// =============================================================

model Dealer {
  id           String       @id @default(cuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName String
  city         String
  phone        String
  whatsapp     String?
  gstin        String?
  gstVerified  Boolean      @default(false)
  status       DealerStatus @default(ACTIVE)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  store         Store?
  listings      Listing[]
  enquiries     Enquiry[]
  subscription  Subscription?
  conversations Conversation[]
  apiKeys       ApiKey[]
  inspections   Inspection[]
  payouts       Payout[]
}

model Store {
  id           String   @id @default(cuid())
  dealerId     String   @unique
  dealer       Dealer   @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  slug         String   @unique
  logoUrl      String?
  bannerUrl    String?
  bio          String?
  primaryColor String   @default("#DC2626")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// =============================================================
// Listings
// =============================================================

model Listing {
  id                String        @id @default(cuid())
  dealerId          String
  dealer            Dealer        @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  vehicleType       VehicleType
  make              String
  model             String
  year              Int
  fuelType          FuelType
  transmission      Transmission?
  odometerKm        Int
  askingPrice       Decimal       @db.Decimal(12, 2)
  description       String?       @db.Text
  city              String
  status            ListingStatus @default(ACTIVE)
  viewCount         Int           @default(0)
  enquiryCount      Int           @default(0)
  isBoosted         Boolean       @default(false)
  boostExpiresAt    DateTime?
  insuranceProvider String?
  insuranceExpiry   DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  photos           ListingPhoto[]
  photos360        Listing360Photo[]
  enquiries        Enquiry[]
  savedBy          SavedListing[]
  conversations    Conversation[]
  inspections      Inspection[]
  loanApplications LoanApplication[]
  listingViews     ListingView[]

  @@index([city, vehicleType, status])
  @@index([dealerId, status])
  @@index([status, createdAt])
  @@index([isBoosted, status, createdAt])
  @@index([boostExpiresAt])
  @@index([insuranceExpiry])
}

model ListingView {
  id        String   @id @default(cuid())
  listingId String
  visitorId String
  createdAt DateTime @default(now())

  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([listingId, visitorId])
}

model ListingPhoto {
  id        String  @id @default(cuid())
  listingId String
  listing   Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  sortOrder Int     @default(0)

  @@index([listingId, sortOrder])
}

model Listing360Photo {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  angle     Int
  createdAt DateTime @default(now())

  @@index([listingId, angle])
}

// =============================================================
// Leads
// =============================================================

model Enquiry {
  id          String        @id @default(cuid())
  listingId   String
  listing     Listing       @relation(fields: [listingId], references: [id], onDelete: Cascade)
  dealerId    String
  dealer      Dealer        @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  buyerId     String?
  buyer       User?         @relation(fields: [buyerId], references: [id])
  buyerName   String
  buyerPhone  String
  buyerEmail  String?
  message     String?
  source      EnquirySource @default(FORM)
  priority    Int           @default(0)
  isRead      Boolean       @default(false)
  isContacted Boolean       @default(false)
  createdAt   DateTime      @default(now())

  @@index([dealerId, isRead, priority, createdAt])
  @@index([listingId, createdAt])
}

// =============================================================
// Chat
// =============================================================

model Conversation {
  id            String    @id @default(cuid())
  listingId     String
  listing       Listing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId       String
  buyer         User      @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  dealerId      String
  dealer        Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  // Denormalised for chat-list ordering. Set on every Message insert so the
  // ordering is stable even when other Conversation fields don't change.
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  messages Message[]

  @@unique([listingId, buyerId])
  @@index([buyerId])
  @@index([dealerId])
  @@index([lastMessageAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body           String       @db.Text
  readAt         DateTime?
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
  @@index([conversationId, readAt])
}

// =============================================================
// Saved (wishlist)
// =============================================================

model SavedListing {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, listingId])
  @@index([userId])
}

// =============================================================
// Developer API
// =============================================================

model ApiKey {
  id         String    @id @default(cuid())
  dealerId   String
  dealer     Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  name       String
  // Legacy plaintext column kept nullable for the migration window.
  // New keys never write this; once all rows have keyHash, drop the column.
  key        String?   @unique
  // SHA-256 hex of the plaintext key. Validation hashes the incoming key and
  // looks up by this. Cannot be reversed; plaintext is shown to the dealer once.
  keyHash    String?   @unique
  // First 8 chars of plaintext for the UI to display (e.g. "wk_abc12…").
  keyPrefix  String?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([dealerId])
  @@index([key])
  @@index([keyHash])
}

// =============================================================
// Payouts
// =============================================================

model Payout {
  id               String       @id @default(cuid())
  dealerId         String
  dealer           Dealer       @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  amount           Decimal      @db.Decimal(12, 2)
  status           PayoutStatus @default(PENDING)
  razorpayPayoutId String?
  note             String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([dealerId])
  @@index([status])
}

enum PayoutStatus {
  PENDING
  APPROVED
  REJECTED
  PAID
}

// =============================================================
// Quality Inspection
// =============================================================

model Inspector {
  id            String          @id @default(cuid())
  userId        String          @unique
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  certification String?
  status        InspectorStatus @default(PENDING)
  createdAt     DateTime        @default(now())

  inspections Inspection[]
}

model Inspection {
  id           String           @id @default(cuid())
  listingId    String
  listing      Listing          @relation(fields: [listingId], references: [id], onDelete: Cascade)
  inspectorId  String?
  inspector    Inspector?       @relation(fields: [inspectorId], references: [id], onDelete: SetNull)
  dealerId     String
  dealer       Dealer           @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  status       InspectionStatus @default(REQUESTED)
  checklist    Json?
  overallScore Int?
  notes        String?          @db.Text
  reportUrl    String?
  createdAt    DateTime         @default(now())
  completedAt  DateTime?

  @@index([listingId])
  @@index([dealerId])
  @@index([inspectorId])
  @@index([status])
}

enum InspectorStatus {
  PENDING
  APPROVED
  REJECTED
}

enum InspectionStatus {
  REQUESTED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

// =============================================================
// Community
// =============================================================

model Post {
  id        String    @id @default(cuid())
  title     String
  body      String    @db.Text
  authorId  String
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  community Community @default(BUYER)
  tags      String[]
  isPinned  Boolean   @default(false)
  isLocked  Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  replies Reply[]
  upvotes PostUpvote[]

  @@index([community, isPinned, createdAt])
  @@index([authorId])
  @@index([tags], type: Gin)
}

model Reply {
  id        String   @id @default(cuid())
  postId    String
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String   @db.Text
  createdAt DateTime @default(now())

  @@index([postId, createdAt])
}

model PostUpvote {
  id     String @id @default(cuid())
  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
}

enum Community {
  BUYER
  DEALER
}

// =============================================================
// Financial Products
// =============================================================

model LoanApplication {
  id             String     @id @default(cuid())
  listingId      String
  listing        Listing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyerId        String
  buyer          User       @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  nbfc           NBFC
  amount         Decimal    @db.Decimal(12, 2)
  tenureMonths   Int
  monthlyEmi     Decimal    @db.Decimal(12, 2)
  status         LoanStatus @default(PENDING)
  applicantName  String
  applicantPhone String
  applicantPan   String?
  notes          String?    @db.Text
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@unique([buyerId, listingId])
  @@index([listingId])
  @@index([buyerId, createdAt])
  @@index([status, createdAt])
}

enum NBFC {
  BAJAJ_FINSERV
  HDFC_BANK
  ICICI_BANK
  MAHINDRA_FINANCE
  KOTAK_MAHINDRA
  CHOLAMANDALAM
  SHRIRAM_FINANCE
  SUNDARAM_FINANCE
  TATA_CAPITAL
  OTHER
}

enum LoanStatus {
  PENDING
  IN_REVIEW
  APPROVED
  REJECTED
  DISBURSED
}

// =============================================================
// Notifications
// =============================================================

model NotificationTemplate {
  id        String       @id @default(cuid())
  name      String       @unique
  subject   String
  body      String       @db.Text
  type      TemplateType @default(EMAIL)
  updatedAt DateTime     @updatedAt
}

enum TemplateType {
  EMAIL
  SMS
}

// =============================================================
// Subscriptions
// =============================================================

model Subscription {
  id               String    @id @default(cuid())
  dealerId         String    @unique
  dealer           Dealer    @relation(fields: [dealerId], references: [id], onDelete: Cascade)
  plan             PlanTier  @default(FREE_TRIAL)
  status           SubStatus @default(TRIALING)
  razorpaySubId    String?   @unique
  currentPeriodEnd DateTime
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

// =============================================================
// Payments — idempotency + webhook replay protection
// =============================================================

model Payment {
  id                String        @id @default(cuid())
  // Razorpay order id (boost orders) — null for raw webhook events that
  // don't carry an order context.
  razorpayOrderId   String?
  // Razorpay payment id — unique gates boost-verify idempotency. A second
  // verify of the same payment hits P2002 and we return "already processed".
  razorpayPaymentId String?       @unique
  // Razorpay webhook event id — unique gates replay protection. A replayed
  // webhook hits P2002 and is dropped silently.
  razorpayEventId   String?       @unique
  // Captured HMAC signature for audit / debugging.
  razorpaySignature String?
  kind              PaymentKind
  // Amount in paise (integer) — INR multiplied by 100.
  amount            Int
  currency          String        @default("INR")
  status            PaymentStatus @default(SUCCEEDED)
  // Free-form context: { dealerId, listingId, duration, … } so we can
  // reconcile without joining back to Razorpay.
  notes             Json?
  dealerId          String?
  listingId         String?
  createdAt         DateTime      @default(now())

  @@index([dealerId, createdAt])
  @@index([listingId, createdAt])
  @@index([kind, createdAt])
}

enum PaymentKind {
  BOOST
  SUBSCRIPTION
  WEBHOOK
}

enum PaymentStatus {
  SUCCEEDED
  FAILED
  REFUNDED
}

// =============================================================
// Enums
// =============================================================

enum Role {
  BUYER
  DEALER
  ADMIN
}

enum DealerStatus {
  ACTIVE
  SUSPENDED
}

enum VehicleType {
  CAR
  BIKE
}

enum FuelType {
  PETROL
  DIESEL
  CNG
  ELECTRIC
  HYBRID
}

enum Transmission {
  MANUAL
  AUTOMATIC
  AMT
  CVT
}

enum ListingStatus {
  ACTIVE
  PAUSED
  SOLD
}

enum EnquirySource {
  FORM
  WHATSAPP
  CALL
}

enum PlanTier {
  FREE_TRIAL
  MONTHLY
  YEARLY
}

enum SubStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
}
